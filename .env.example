# Root .env template for docker-compose.yml.
# Copy to .env and fill in real values:  cp .env.example .env
# The .env file is gitignored — never commit real secrets.

# --- Required secrets (compose aborts if these are unset) ---
# Strong password for the containerized Postgres database.
POSTGRES_PASSWORD=
# Shared secret for internal BFF routes + board socket HMAC. MUST be identical for web & api.
INTERNAL_API_KEY=
# NextAuth (Auth.js) JWT signing secret. Generate with: npx auth secret
AUTH_SECRET=

# --- Optional overrides (sensible defaults live in docker-compose.yml) ---
# POSTGRES_USER=postgres
# POSTGRES_DB=canvus
# ALLOWED_ORIGIN=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:4000
# ENABLE_GUEST_CANVASES=true

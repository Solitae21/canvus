# Development
NEXT_PUBLIC_API_URL=http://localhost:4000

# Auth.js (NextAuth v5) — required
# Generate with: npx auth secret
AUTH_SECRET=
# Optional: set when running on a non-default host (e.g. behind a proxy)
# AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Prisma — must match apps/api/.env so web and api share the DB
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/canvus?schema=public

{
  "name": "@canvus/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "predev": "npm run generate",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "prebuild": "npm run generate",
    "generate": "prisma generate && tsc -p tsconfig.prisma-client.json",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:dev": "cross-env NODE_ENV=development node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test:redis": "tsx test/redis-pubsub.test.ts"
  },
  "dependencies": {
    "@canvus/shared": "*",
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.13",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "typescript": "^5",
    "ws": "^8.18.0",
    "y-socket.io": "^1.1.3",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "prisma": "^6.19.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.59.2"
  }
}

NODE_ENV=development
HOST=127.0.0.1
PORT=4000
ALLOWED_ORIGIN=http://localhost:3000
ALLOW_GLOBAL_CANVAS_LIST=false
REDIS_URL=redis://localhost:6379

# Number of proxy hops in front of the API (most PaaS = 1). Required for per-IP
# rate limiting to see the real client IP. "false" in local/dev (no proxy).
# Defaults to 1 in production, false otherwise.
# TRUST_PROXY=1

# Set to "false" to disable the legacy unauthenticated guest canvas store and
# its WebSocket rooms (authenticated boards are unaffected). Default: enabled.
# ENABLE_GUEST_CANVASES=true

# Shared secret for internal (BFF) routes. MUST match apps/web INTERNAL_API_KEY.
INTERNAL_API_KEY=dev-internal-key-change-me

# Prisma — the API is the only service with database access.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/canvus?schema=public
# Direct (non-pooled) connection used by Prisma CLI for migrations.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/canvus?schema=public
